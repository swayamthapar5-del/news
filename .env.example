# NewsAPI.org Configuration
# Get your free API key from: https://newsapi.org
VITE_NEWS_API_KEY=your_news_api_key_here

# Optional: Custom API endpoint (leave as is for NewsAPI.org)
VITE_NEWS_API_BASE_URL=https://newsapi.org/v2

# Twitter/X API Configuration
# Get your API keys from: https://developer.twitter.com
VITE_TWITTER_API_KEY=your_twitter_api_key_here
VITE_TWITTER_API_SECRET=your_twitter_api_secret_here
VITE_TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here
VITE_TWITTER_API_BASE_URL=https://api.x.com/2
